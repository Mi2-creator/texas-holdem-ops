# =============================================================================
# Texas Hold'em Server - Local Development Environment
# Backend API stack only (Go server + PostgreSQL)
# Mobile app (player-app) runs on device/simulator, connects to this API
# Copy to .env and customize
# =============================================================================

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
HTTP_ADDR=:8080
HOST_PORT=8080

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Storage (file-based hand/rake/audit exports)
# -----------------------------------------------------------------------------
STORAGE_MODE=file
DATA_DIR=./data

# -----------------------------------------------------------------------------
# PostgreSQL (wallet, ledger, topup orders, audit logs)
# -----------------------------------------------------------------------------
DB_DRIVER=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=texasholdem
DB_USER=texasholdem
DB_PASSWORD=changeme
DB_SSLMODE=disable

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# X-Admin-Token header for /v1/admin/* endpoints
ADMIN_TOKEN=change-this-to-a-random-secret
# Super admin account (seeded on startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Server Lifecycle
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT=30
SOFT_LAUNCH=false
READ_ONLY=false
SHUTDOWN=false

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=10.0
RATE_LIMIT_BURST=20

# -----------------------------------------------------------------------------
# Domain (used by Caddy in prod; defaults fine for local dev)
# -----------------------------------------------------------------------------
DOMAIN=localhost
API_DOMAIN=api.localhost

# -----------------------------------------------------------------------------
# Build (set during CI/CD or by Makefile)
# -----------------------------------------------------------------------------
VERSION=dev
GIT_COMMIT=unknown
BUILD_TIME=unknown

# -----------------------------------------------------------------------------
# Source path (for docker build context)
# -----------------------------------------------------------------------------
SERVER_SRC=../../texas-holdem-client
