# =============================================================================
# Texas Hold'em Server - Production Environment Configuration
# This configures the BACKEND API stack (Go server + PostgreSQL + Caddy)
# Mobile app (player-app) is NOT deployed via this file
# Copy to .env.prod and fill in real values before deploying
#
# REQUIRED by deploy_prod.sh:
#   SERVER_HOST, SERVER_USER, SERVER_DIR, DOMAIN, DB_PASSWORD, ADMIN_TOKEN
# REQUIRED by make prod-env-check (adds):
#   DB_DRIVER, DB_NAME, DB_USER, ADMIN_USERNAME, ADMIN_PASSWORD
# REQUIRED by generate_caddyfile.sh (for play subdomain):
#   API_DOMAIN, PLAY_DOMAIN
# =============================================================================

# -----------------------------------------------------------------------------
# Remote Server
# -----------------------------------------------------------------------------
SERVER_HOST=your-server-ip-or-hostname
SERVER_USER=deploy
SERVER_DIR=/opt/texas-holdem-ops
# SSH port (default 22; change if your server uses a non-standard port)
SSH_PORT=2222

# -----------------------------------------------------------------------------
# Domain & HTTPS (Caddy auto-TLS)
# -----------------------------------------------------------------------------
# Root domain — landing page / download page (Caddy serves static files)
DOMAIN=pokeryapp.com
# API subdomain — mobile app connects to this; Caddy reverse proxies to Go backend
API_DOMAIN=api.pokeryapp.com
# Play subdomain — H5 web client (static files served by Caddy)
PLAY_DOMAIN=play.pokeryapp.com
# Admin API: same as API_DOMAIN, /v1/admin/* endpoints, protected by ADMIN_TOKEN header
# Mobile app base URL = https://API_DOMAIN

# -----------------------------------------------------------------------------
# Docker Compose
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=texas-holdem

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
HTTP_ADDR=:8080
# HOST_PORT not used in prod (Caddy proxies internally)
HOST_PORT=8080

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Storage (file-based hand/rake/audit exports)
# -----------------------------------------------------------------------------
STORAGE_MODE=file
DATA_DIR=./data

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_DRIVER=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=texasholdem
DB_USER=texasholdem
# IMPORTANT: Change to a strong random password (e.g. openssl rand -base64 32)
DB_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
DB_SSLMODE=disable

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# IMPORTANT: Change to a strong random token (e.g. openssl rand -hex 32)
ADMIN_TOKEN=CHANGE_ME_STRONG_RANDOM_TOKEN
# Super admin account seeded on startup
ADMIN_USERNAME=admin
# IMPORTANT: Change to a strong password
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# -----------------------------------------------------------------------------
# Server Lifecycle
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT=30
SOFT_LAUNCH=false
READ_ONLY=false
SHUTDOWN=false

# -----------------------------------------------------------------------------
# CORS (cross-origin requests from H5 client)
# -----------------------------------------------------------------------------
# Comma-separated origins. Set to https://play.pokeryapp.com for production.
CORS_ORIGINS=https://play.pokeryapp.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=10.0
RATE_LIMIT_BURST=20

# -----------------------------------------------------------------------------
# Build / Image
# -----------------------------------------------------------------------------
VERSION=latest
GIT_COMMIT=unknown
BUILD_TIME=unknown
# On server: ".." (Go source is at SERVER_DIR/server/go/, context = parent of docker/)
# On local dev: "../../texas-holdem-client" (sibling repo)
SERVER_SRC=..
